@{
    ViewData["Title"] = "Login";
}

@inject IConfiguration Configuration

<div class="row justify-content-center mt-5">
    <div class="col-md-4">
        <div class="card">
            <div class="card-body text-center">
                <h3>Sign In</h3>
                <hr/>
                @if (!string.IsNullOrWhiteSpace(Configuration["Auth:Google:ClientId"]))
                {
                    <a href="/Account/LoginWithGoogle" class="btn btn-danger w-100">
                        Sign in with Google
                    </a>
                }
                @if (!string.IsNullOrWhiteSpace(Configuration["Auth:GitHub:ClientId"]))
                {
                    <a href="/Account/LoginWithGitHub" class="btn btn-dark w-100 mt-2">
                        Sign in with GitHub
                    </a>
                }
            </div>
        </div>
    </div>
</div>
