@{
    ViewData["Title"] = "Home Page";
    var vm = Model as InventoryApp.Web.Controllers.HomeController.HomeViewModel;
    string T(string en, string ru)
    {
        var lang = System.Threading.Thread.CurrentThread.CurrentUICulture.TwoLetterISOLanguageName;
        return lang == "ru" ? ru : en;
    }
}

<h2>@T("Latest inventories","Последние инвентари")</h2>
<table class="table table-hover">
    <thead>
        <tr>
            <th>Title</th>
            <th>Creator</th>
            <th>Created</th>
        </tr>
    </thead>
    <tbody>
        @foreach (var inv in vm?.LatestInventories ?? new List<InventoryApp.Web.Models.Inventory>())
        {
            <tr style="cursor:pointer" onclick="window.location='/Inventory/Details/@inv.Id'">
                <td>@inv.Title</td>
                <td>@(inv.Creator?.DisplayName ?? inv.Creator?.UserName ?? "—")</td>
                <td>@inv.CreatedAt.ToString("yyyy-MM-dd")</td>
            </tr>
        }
    </tbody>
</table>

<h2 class="mt-4">@T("Top inventories (by items)","Топ инвентарей (по items)")</h2>
<table class="table table-hover">
    <thead>
        <tr>
            <th>Title</th>
            <th>Creator</th>
        </tr>
    </thead>
    <tbody>
        @foreach (var inv in vm?.TopInventories ?? new List<InventoryApp.Web.Models.Inventory>())
        {
            <tr style="cursor:pointer" onclick="window.location='/Inventory/Details/@inv.Id'">
                <td>@inv.Title</td>
                <td>@(inv.Creator?.DisplayName ?? inv.Creator?.UserName ?? "—")</td>
            </tr>
        }
    </tbody>
</table>

<h2 class="mt-4">@T("Tags","Теги")</h2>
<div class="d-flex flex-wrap gap-2">
    @foreach (var tag in vm?.Tags ?? new List<string>())
    {
        <a class="badge bg-secondary text-decoration-none" href="/Search?q=@tag">@tag</a>
    }
</div>
