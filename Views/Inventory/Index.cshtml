@model IEnumerable<InventoryApp.Web.Models.Inventory>

@{
    ViewData["Title"] = "Inventories";
    string T(string en, string ru)
    {
        var lang = System.Threading.Thread.CurrentThread.CurrentUICulture.TwoLetterISOLanguageName;
        return lang == "ru" ? ru : en;
    }
}

<h2>@T("Inventories","Инвентари")</h2>

<a href="/Inventory/Create" class="btn btn-primary mb-3">@T("+ New inventory","+ Новый инвентарь")</a>

<table class="table table-hover">
    <thead>
        <tr>
            <th>@T("Title","Название")</th>
            <th>@T("Category","Категория")</th>
            <th>@T("Creator","Создатель")</th>
            <th>@T("Created","Создан")</th>
            <th>@T("Public","Публичный")</th>
        </tr>
    </thead>
    <tbody>
        @foreach (var inv in Model)
        {
            <tr style="cursor:pointer" onclick="window.location='/Inventory/Details/@inv.Id'">
                <td>@inv.Title</td>
                <td>@(inv.Category?.Name ?? "—")</td>
                <td>@(inv.Creator?.DisplayName ?? inv.Creator?.UserName ?? "—")</td>
                <td>@inv.CreatedAt.ToString("yyyy-MM-dd")</td>
                <td>@(inv.IsPublic ? "✓" : "")</td>
            </tr>
        }
    </tbody>
</table>
