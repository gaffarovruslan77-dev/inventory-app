<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] - InventoryApp</title>
    <link rel="stylesheet" href="~/lib/bootstrap/dist/css/bootstrap.min.css" />
    <link rel="stylesheet" href="~/css/site.css" asp-append-version="true" />
</head>
<body>
@{
    string T(string en, string ru)
    {
        var lang = System.Threading.Thread.CurrentThread.CurrentUICulture.TwoLetterISOLanguageName;
        return lang == "ru" ? ru : en;
    }
}
    <header>
        <nav class="navbar navbar-expand-sm navbar-light bg-white border-bottom mb-3">
            <div class="container">
                <a class="navbar-brand" asp-controller="Home" asp-action="Index">Inventory App</a>
                <button class="navbar-toggler" type="button" data-bs-toggle="collapse" data-bs-target=".navbar-collapse">
                    <span class="navbar-toggler-icon"></span>
                </button>
                <div class="navbar-collapse collapse d-sm-inline-flex justify-content-between">
                    <ul class="navbar-nav flex-grow-1">
                        <li class="nav-item">
                            <a class="nav-link text-dark" asp-controller="Home" asp-action="Index">@T("Home","Главная")</a>
                        </li>
                        <li class="nav-item">
                            <a class="nav-link text-dark" asp-controller="Inventory" asp-action="Index">@T("Inventories","Инвентари")</a>
                        </li>
                    </ul>
                    <form class="d-flex me-3" method="get" action="/Search">
                        <input class="form-control form-control-sm me-2" name="q" placeholder="@T("Search...","Поиск...")" />
                        <button class="btn btn-outline-primary btn-sm" type="submit">@T("Go","Найти")</button>
                    </form>
                    <ul class="navbar-nav">
                        <li class="nav-item me-2">
                            <button type="button" class="btn btn-outline-secondary btn-sm" id="themeToggle">
                                @T("Theme","Тема")
                            </button>
                        </li>
                        <li class="nav-item me-2">
                            <form method="post" action="/Ui/SetLanguage" class="d-flex">
                                @Html.AntiForgeryToken()
                                <input type="hidden" name="returnUrl" value="@Context.Request.Path@Context.Request.QueryString" />
                                <select class="form-select form-select-sm" name="culture" onchange="this.form.submit()">
                                    <option value="en" selected="@(System.Threading.Thread.CurrentThread.CurrentUICulture.TwoLetterISOLanguageName == "en")">EN</option>
                                    <option value="ru" selected="@(System.Threading.Thread.CurrentThread.CurrentUICulture.TwoLetterISOLanguageName == "ru")">RU</option>
                                </select>
                            </form>
                        </li>
                        @if (User.Identity?.IsAuthenticated == true)
                        {
                            @if (User.IsInRole("Admin"))
                            {
                                <li class="nav-item">
                                    <a class="nav-link text-dark" asp-controller="Admin" asp-action="Index">@T("Admin","Админ")</a>
                                </li>
                            }
                            <li class="nav-item">
                                <a class="nav-link text-dark" asp-controller="Profile" asp-action="Index">@T("Profile","Профиль")</a>
                            </li>
                            <li class="nav-item">
                                <span class="nav-link text-dark">@User.Identity.Name</span>
                            </li>
                            <li class="nav-item">
                                <a class="nav-link text-dark" asp-controller="Account" asp-action="Logout">@T("Logout","Выйти")</a>
                            </li>
                        }
                        else
                        {
                            <li class="nav-item">
                                <a class="nav-link text-dark" asp-controller="Account" asp-action="Login">@T("Login","Войти")</a>
                            </li>
                        }
                    </ul>
                </div>
            </div>
        </nav>
    </header>
    <div class="container">
        <main role="main" class="pb-3">
            @RenderBody()
        </main>
    </div>
    <footer class="border-top footer text-muted">
        <div class="container">
            &copy; 2026 - Inventory App
        </div>
    </footer>
    <script src="~/lib/jquery/dist/jquery.min.js"></script>
    <script src="~/lib/bootstrap/dist/js/bootstrap.bundle.min.js"></script>
    <script>
    (function () {
        const key = 'theme';
        function apply(t) {
            document.body.classList.remove('theme-dark');
            if (t === 'dark') document.body.classList.add('theme-dark');

            const nav = document.querySelector('nav.navbar');
            if (nav) {
                nav.classList.remove('navbar-light', 'bg-white', 'navbar-dark', 'bg-dark');
                if (t === 'dark') {
                    nav.classList.add('navbar-dark');
                } else {
                    nav.classList.add('navbar-light', 'bg-white');
                }
            }
        }
        const saved = localStorage.getItem(key) || 'light';
        apply(saved);
        const btn = document.getElementById('themeToggle');
        if (btn) {
            btn.addEventListener('click', () => {
                const next = (localStorage.getItem(key) || 'light') === 'dark' ? 'light' : 'dark';
                localStorage.setItem(key, next);
                apply(next);
            });
        }
    })();
    </script>
</body>
</html>
